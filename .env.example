# Copy to `.env` (gitignored). Restart `npm run dev` after editing.

# Web App URL only — from Deploy → copy URL ending in `/exec`
# (Uses the deployment hash, e.g. .../macros/s/AKfyc.../exec — NOT the library link.)
# VITE_LEADS_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_HASH/exec

# SHEET_ID belongs in Google Apps Script (`scripts/leads-google-apps-script.gs` lives there too).
# Use the ID from: docs.google.com/spreadsheets/d/PASTE_HERE/edit
# Do not use: script “library” ID, “project” ID, or deployment hash for SHEET_ID.
